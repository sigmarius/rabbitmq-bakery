  "vhosts": [
    {
      "name": "bakery"
    },
    {
      "name": "bakery_archive"
    }
  ],
  "permissions": [
    {
      "user": "admin_bakery",
      "vhost": "bakery",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "admin_bakery",
      "vhost": "bakery_archive",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "shop_app",
      "vhost": "bakery",
      "configure": "^$",
      "write": "^(ex\\.orders|ex\\.orders\\.delayed)$",
      "read": "^$"
    },
    {
      "user": "warehouse_app",
      "vhost": "bakery",
      "configure": "^$",
      "write": "^(ex\\.packing|ex\\.delivery)$",
      "read": "^q\\.orders\\.picking$"
    },
    {
      "user": "production_app",
      "vhost": "bakery",
      "configure": "^$",
      "write": "^(ex\\.inventory|ex\\.alerts|ex\\.production)$",
      "read": "^q\\.production\\.bake$"
    },
    {
      "user": "courier_app",
      "vhost": "bakery",
      "configure": "^$",
      "write": "^ex\\.orders$",
      "read": "^q\\.delivery\\.pending$"
    },
    {
      "user": "procurement_app",
      "vhost": "bakery",
      "configure": "^$",
      "write": "^$",
      "read": "^q\\.inventory\\.signals$"
    },
    {
      "user": "ops_shovel",
      "vhost": "bakery",
      "configure": "^$",
      "write": "^$",
      "read": "^q\\.orders\\.completed$"
    },
    {
      "user": "ops_shovel",
      "vhost": "bakery_archive",
      "configure": "^$",
      "write": "^(q\\.archived\\.orders|amq\\.default)$",
      "read": "^$"
    },
    {
      "user": "federation_link",
      "vhost": "bakery",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "mqtt_stomp",
      "vhost": "bakery",
      "configure": "^$",
      "write": "^amq\\.topic$",
      "read": "^amq\\.topic$"
    },
    {
      "user": "notifier_app",
      "vhost": "bakery",
      "configure": "^$",
      "write": "^$",
      "read": "^q\\.orders\\.sms_sim$"
    },
    {
      "user": "federation_link",
      "vhost": "bakery_archive",
      "configure": "^ex\\.inventory$",
      "write": "^ex\\.inventory$",
      "read": "^q\\.inventory\\.replica$"
    }
  ],
